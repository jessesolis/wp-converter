PORT=3001

# Match the credentials in the repo-root docker-compose.yml.
DATABASE_URL=postgres://scorpion:scorpion@localhost:5432/scorpion_wp_converter
REDIS_URL=redis://localhost:6379

TEMP_DIR=/tmp/scorpion-conversions

# Frontend (set in `frontend/.env.local`, not here):
# NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:3001
# The frontend's WebSocket client uses this to bypass Next.js's HTTP-only
# rewrite proxy. Defaults to ws://localhost:3001 if unset.
